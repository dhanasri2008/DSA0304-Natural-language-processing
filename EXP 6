import random

text = "I love natural language processing and I love python"

words = text.split()

# Create bigrams
bigrams = {}
for i in range(len(words) - 1):
    if words[i] not in bigrams:
        bigrams[words[i]] = []
    bigrams[words[i]].append(words[i + 1])

# Generate text
word = random.choice(words)
result = [word]

for _ in range(10):
    if word in bigrams:
        word = random.choice(bigrams[word])
        result.append(word)
    else:
        break

print("Generated Text:")
print(" ".join(result))
